# ------------------------------------------------------------------
# Template for .env — copy to `.env` and fill in your values:
#     cp .env.example .env
# This file IS committed (no secrets). The real `.env` is git-ignored.
#
# The Higgsfield MCP needs NO key here (it authenticates via OAuth: run `/mcp`).
# Use these only if you call the Higgsfield API / CLI / SDK directly from scripts.
# Load with Node's built-in flag:
#     node --env-file=.env src/scripts/<name>.ts
# ------------------------------------------------------------------

# Higgsfield API credentials — a key id + secret PAIR.
# Create them at https://cloud.higgsfield.ai/api-keys
# Official SDKs (higgsfield-js / higgsfield-client) read these exact names:
HF_API_KEY=
HF_API_SECRET=

# ...or the combined form (the SDK checks this first if set):
# HF_KEY=<key-id>:<secret>
