{
  "name": "higgsfield-quantum-bitcoin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Higgsfield production environment for the Quantum Bitcoin Elements 9-scene explainer (driven via the Higgsfield MCP).",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "export:prompts": "node --disable-warning=ExperimentalWarning src/core/scripts/export-prompts.ts",
    "shot-list": "node --disable-warning=ExperimentalWarning src/core/scripts/shot-list.ts",
    "plan:report": "node --disable-warning=ExperimentalWarning src/core/scripts/plan-report.ts",
    "check:auth": "node --disable-warning=ExperimentalWarning --env-file=.env src/api/scripts/check-auth.ts",
    "generate:keyframe": "node --disable-warning=ExperimentalWarning --env-file=.env src/api/scripts/generate-keyframe.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@higgsfield/client": "^0.2.1"
  }
}
