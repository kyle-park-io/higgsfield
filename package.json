{
  "name": "higgsfield-cutscenes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Higgsfield cutscene monorepo — shared src/ tooling over independent projects under projects/<name>/ (select with --project). First project: Quantum Bitcoin Elements.",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "export:prompts": "node --disable-warning=ExperimentalWarning src/core/scripts/export-prompts.ts",
    "shot-list": "node --disable-warning=ExperimentalWarning src/core/scripts/shot-list.ts",
    "plan:report": "node --disable-warning=ExperimentalWarning src/core/scripts/plan-report.ts",
    "models": "node --disable-warning=ExperimentalWarning src/mcp/scripts/model-report.ts",
    "check:auth": "node --disable-warning=ExperimentalWarning --env-file=.env src/api/scripts/check-auth.ts",
    "generate:keyframe": "node --disable-warning=ExperimentalWarning --env-file=.env src/api/scripts/generate-keyframe.ts",
    "generate:keyframe:dry": "node --disable-warning=ExperimentalWarning --env-file=.env src/api/scripts/generate-keyframe.ts --dry-run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@higgsfield/client": "^0.2.1"
  }
}
